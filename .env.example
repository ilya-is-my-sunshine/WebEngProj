PORT=3001
SQLITE_PATH=/absolute/path/to/webeng-admin.sqlite
ALLOWED_ORIGINS=http://localhost:5173
VITE_API_BASE_URL=http://localhost:3001

# Production deployment note:
# Leave VITE_API_BASE_URL unset when deploying the static site without the admin API.
# Future backend persistence for multiple admins should move to PostgreSQL.
